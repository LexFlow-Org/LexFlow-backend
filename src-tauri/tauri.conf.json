{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LexFlow",
  "version": "1.5.0",
  "identifier": "com.pietrolongo.lexflow",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd client && npm run dev",
    "beforeBuildCommand": "cd client && npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    },
    "macOSPrivateApi": false,
    "windows": [
      {
        "label": "main",
        "title": "LexFlow",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "visible": true,
        "backgroundColor": "#08090f",
        "backgroundThrottling": "disabled"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "infoPlist": "Info.plist"
    },
    "android": {
      "minSdkVersion": 24,
      "versionCode": 150
    },
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "wix": {
        "language": "it-IT"
      }
    }
  },
  "plugins": {}
}
